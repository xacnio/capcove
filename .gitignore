# Environment — contains API credentials, never commit
.env

# Updater signing keys — the private key must stay secret; the public key
# isn't sensitive but is already embedded in src-tauri/tauri.conf.json
# (pubkey), so tracking the file too is just redundant.
updater.key
updater.key.pub

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-xacnio-dev
dist-ssr
*.local
src/data/legal.json

# Generated by --store-screenshots (dev-only)
/store-screenshots/

# ffmpeg/ffprobe sidecars — ~137MB each, over GitHub's 100MB per-file push
# limit without Git LFS. CI fetches a pinned BtbN/FFmpeg-Builds release
# instead (see release.yml/build-artifacts.yml, and src-tauri/src/
# integrity.rs for the hash pins); for local dev, grab the same build
# yourself and place it here (path/name must match `bundle.externalBin` in
# tauri.conf.json).
src-tauri/binaries/*.exe

# Microsoft Store submission: local test cert + Partner Center API secrets,
# and the per-submission "what's new" draft text (submit-store.ps1 handles
# it being absent fine — it just skips applying release notes).
scripts/msix/.cert/
scripts/.store-credentials.ps1
scripts/release-notes.json
*.msix

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
